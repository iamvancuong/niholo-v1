            "grammar": {
                "g1": {
                    "title": "(EN) Khẳng định: N1 は N2 です",
                    "description": "(EN) Dùng để giới thiệu N1 là N2. Trợ từ 'は' đọc là 'wa'.",
                    "exercises": {
                        "ex1": "(EN) Tôi là học sinh.",
                        "ex2": "(EN) Cô ấy là người Việt Nam."
                    }
                },
                "g2": {
                    "title": "(EN) Phủ định: N1 は N2 じゃありません",
                    "description": "(EN) Dùng để phủ định: N1 không phải là N2.",
                    "exercises": {
                        "ex1": "(EN) Anh ấy không phải là giáo viên."
                    }
                },
                "g3": {
                    "title": "(EN) Câu hỏi: N1 は N2 ですか \/ Từ để hỏi: だれ",
                    "description": "(EN) Dùng để hỏi N1 có phải là N2 không? Hoặc hỏi thông tin (Ai).",
                    "exercises": {
                        "ex1": "(EN) Bạn là nhân viên ngân hàng phải không?",
                        "ex2": "(EN) Người kia là ai?"
                    }
                },
                "g4": {
                    "title": "(EN) Trợ từ も (Cũng)",
                    "description": "(EN) Dùng để thể hiện sự tương đồng, thay thế cho trợ từ は.",
                    "exercises": {
                        "ex1": "(EN) Tôi cũng là kỹ sư."
                    }
                },
                "g5": {
                    "title": "(EN) Trợ từ の (Sở hữu \/ Bổ nghĩa)",
                    "description": "(EN) Trợ từ **の** nối hai danh từ. N1 bổ nghĩa cho N2 để thể hiện: sở hữu, phạm vi, xuất xứ, loại, v.v.\n\n*Lưu ý:* Khi N2 đã rõ từ ngữ cảnh, có thể bỏ N2 (Ví dụ: `これは わたしの です` - Cái này là của tôi).",
                    "exercises": {
                        "ex1": "(EN) Người kia là nhân viên của IMC."
                    }
                }
            }
        },
